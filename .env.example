# ============================================================
# LumiOS Environment Configuration
# Copy this file to .env and fill in your keys
# ============================================================

# -------------------------------------------------
# LLM Providers (at least one required)
# -------------------------------------------------

# OpenAI
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# DeepSeek (primary — deepseek-chat / deepseek-reasoner)
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# Qwen / DashScope (Alibaba Cloud — also used by CosyVoice TTS)
DASHSCOPE_API_KEY=
# QWEN_API_KEY=           # alias, falls back to DASHSCOPE_API_KEY
# QWEN_MODEL=qwen-plus

# Doubao / Ark (ByteDance Volcengine)
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=doubao-1-5-pro-32k

# Xiaomi (XiaoAi / MiLM)
# XIAOMI_API_KEY=
# XIAOMI_BASE_URL=https://api.xiaomi.com/v1
# XIAOMI_MODEL=xiaomi-chat

# Moonshot / Kimi
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=moonshot-v1-8k

# Zhipu / GLM
# GLM_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4-plus

# Custom OpenAI-compatible relay
# RELAY_API_KEY=
# RELAY_BASE_URL=https://api.example.com/v1

# -------------------------------------------------
# Local LLM (auto-detected, no key needed)
# -------------------------------------------------

# OLLAMA_BASE_URL=http://localhost:11434
# LMSTUDIO_BASE_URL=http://localhost:1234

# -------------------------------------------------
# Voice & Audio
# -------------------------------------------------

# Deepgram (STT — speech to text)
DEEPGRAM_API_KEY=

# Doubao Speech (TTS + STT)
# DOUBAO_SPEECH_KEY=

# GPT-SoVITS (local TTS — requires separate GPT-SoVITS server)
# GPTSOVITS_ENABLED=false
# GPTSOVITS_API_URL=

# -------------------------------------------------
# Auth & Security
# -------------------------------------------------

# JWT signing secret (REQUIRED — use a long random string)
JWT_SECRET=your_jwt_secret_here

# Auto-login password for admin account (local/dev only)
# AUTO_LOGIN_PASSWORD=

# -------------------------------------------------
# Server Config
# -------------------------------------------------

PORT=3000
NODE_ENV=development

# Bind address (default: 0.0.0.0 — all interfaces, required for LAN)
# HOST=0.0.0.0

# Server role: personal (default) or org (enterprise)
# LUMI_ROLE=personal

# Data directory (default: ~/LumiOS/)
# LUMI_DATA_DIR=

# Context token budget for conversations (default: 1,000,000)
# CONTEXT_TOKEN_BUDGET=1000000

# Comma-separated list of allowed shell commands for MCP tools
# LUMI_ALLOWED_COMMANDS=

# -------------------------------------------------
# Messaging Integrations (optional)
# -------------------------------------------------

# Feishu / Lark Bot
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_VERIFICATION_TOKEN=

# WeCom (企业微信) Bot
# WECOM_CORP_ID=
# WECOM_AGENT_ID=
# WECOM_APP_SECRET=
# WECOM_TOKEN=
# WECOM_ENCODING_AES_KEY=

# WeChat Bot
# WECHAT_BOT_TOKEN=
# WECHAT_BOT_ID=
# WECHAT_BASE_URL=https://ilinkai.weixin.qq.com

# -------------------------------------------------
# Cloud & External Services (optional)
# -------------------------------------------------

# Supabase (cloud sync)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=

# GitHub (MCP marketplace)
# GITHUB_TOKEN=

# Alibaba Cloud AK (biometrics / real-name verification)
# ALIYUN_AK_ID=
# ALIYUN_AK_SECRET=

# QiChaCha (enterprise legal verification)
# QICHACHA_API_KEY=

# Email (SMTP for sending invitations etc.)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# SiliconFlow (nanobanana skill)
# SILICONFLOW_API_KEY=

# Netease Cloud Music
# NETEASE_APP_ID=
# NETEASE_PRIVATE_KEY=
