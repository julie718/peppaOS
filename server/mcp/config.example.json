{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": true,
      "source": "external",
      "transport": "stdio",
      "description": "Filesystem access for the Peppa workspace."
    },
    "sqlite": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "data/peppa.db"
      ],
      "enabled": false,
      "source": "external",
      "transport": "stdio",
      "description": "SQLite access for the local Peppa database."
    },
    "git": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-git",
        "."
      ],
      "enabled": false,
      "source": "external",
      "transport": "stdio",
      "description": "Git repository inspection tools."
    }
  },
  "remoteDevices": {}
}
